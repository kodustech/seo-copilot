NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ALLOWED_DOMAIN=@kodus.io
NEXT_PUBLIC_APP_URL=http://localhost:3737

N8N_KEYWORDS_ENDPOINT=https://n8n.kodus.io/webhook/generate-keywords
N8N_KEYWORDS_STATUS_ENDPOINT=https://n8n.kodus.io/webhook/get-task
N8N_KEYWORDS_HISTORY_ENDPOINT=https://n8n.kodus.io/webhook/keywords-history
N8N_TITLES_ENDPOINT=https://n8n.kodus.io/webhook/generate-titles
N8N_BEARER_TOKEN=
N8N_POST_ENDPOINT=https://n8n.kodus.io/webhook/generate-post
N8N_ARTICLES_ENDPOINT=https://n8n.kodus.io/webhook/get-articles

POST_BRIDGE_API_URL=https://api.post-bridge.com
POST_BRIDGE_API_KEY=

CHANGELOG_API_URL=https://changelog-generator.up.railway.app
CHANGELOG_REPOSITORY=kodustech/kodus-ai
CHANGELOG_LOOKBACK_DAYS=30
CHANGELOG_GITHUB_TOKEN=

# --- Email find + verify (research people) ---
# NeverBounce: primary mailbox probe (already used)
NEVERBOUNCE_API_KEY=
# ZeroBounce: secondary when NB returns unknown / missing (helps some catch-alls)
ZEROBOUNCE_API_KEY=
# Hunter: email finder (best for BR when SMTP unprobeable) + optional verify
HUNTER_API_KEY=

# --- Growth Agent ---
EXA_API_KEY=
AI_PROVIDER=kimi
MOONSHOT_API_KEY=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL_KIMI=kimi-k2.7-code
AI_MODEL_GOOGLE=gemini-2.0-flash
AI_MODEL_OPENAI=gpt-4o
AI_MODEL_ANTHROPIC=claude-sonnet-4-20250514

# --- Scheduled Jobs ---
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# --- Outreach mailbox (Gmail OAuth — Settings → Connect with Google) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web)
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/outreach/mailbox/google/callback
# Enable Gmail API on the project.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional dedicated key for encrypting mailbox secrets (defaults to service role).
# OUTREACH_SECRETS_KEY=


# --- CRM ---
# Bearer secret for POST /api/crm/webhook (enrichment flows / n8n).
CRM_WEBHOOK_SECRET=
# Optional: idle-account cron (runs in-process, daily 12:00 UTC) POSTs the
# stale-company list here (e.g. an n8n webhook that routes to Slack). Unset = log only.
CRM_IDLE_WEBHOOK_URL=

# --- DataForSEO (LLM Mentions) ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- BigQuery Analytics ---
BIGQUERY_CREDENTIALS={"type":"service_account","project_id":"kody-408918",...}

# --- Reply Radar (X API) ---
# OAuth 2.0 App-Only Bearer Token from console.x.com
# App → Keys and tokens → Bearer Token → Generate
X_API_BEARER_TOKEN=

# --- MCP HTTP (/api/mcp) ---
# Shared/legacy Bearer (optional if everyone uses personal PATs from Settings)
MCP_AUTH_TOKEN=
MCP_DEFAULT_USER_EMAIL=growth@kodus.io
# Set to false to require personal PATs only
# MCP_ALLOW_SHARED_TOKEN=false
